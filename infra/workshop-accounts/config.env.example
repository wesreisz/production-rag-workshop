#!/usr/bin/env bash
# Workshop Account Configuration
# Copy this file to config.env and update the values below.
#   cp config.env.example config.env
#
# All scripts source config.env automatically.

# Your email address -- Gmail +addressing creates unique emails per student
# e.g., you+workshop-student-01@gmail.com routes to you@gmail.com
EMAIL_BASE="you@gmail.com"

# AWS region for all workshop resources
REGION="us-east-1"

# Organizational Unit name for student accounts
OU_NAME="workshop-students"

# Per-account budget cap in USD
BUDGET_LIMIT="25"

# Prefix for student account names (accounts will be named <prefix>-01, <prefix>-02, etc.)
STUDENT_ACCOUNT_PREFIX="rag-workshop-student"

# IAM role created automatically in child accounts by Organizations
CROSS_ACCOUNT_ROLE="OrganizationAccountAccessRole"

# IAM user created inside each student account for the student to use
STUDENT_IAM_USER="workshop-user"

# Console password for student IAM users (students must change on first login)
STUDENT_DEFAULT_PASSWORD="WorkshopRAG-2026!"

# Notification email for budget alerts (your email)
NOTIFICATION_EMAIL="${EMAIL_BASE}"

# CSV file tracking all student accounts
STUDENTS_CSV="$(dirname "$0")/students.csv"

# Directory for per-student credential files
STUDENTS_DIR="$(dirname "$0")/students"
